{
  "manifest_version": 3,
  "name": "phantom-ng",
  "version": "1.0.0",
  "description": "Splunk SOAR (Phantom) Artifacts 详情面板优化",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_end"
    }
  ]
}